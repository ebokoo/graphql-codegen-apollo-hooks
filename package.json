    "hooks",
    "react",
    "usequery",
    "usemutation",
    "usesubscription",
    "typescript",
    "typed",
    "auto-generated-hooks",
    "graphql-hooks",
    "react-hooks",
    "type-safety",
    "type-safe",
    "replace-typescript-react-apollo"
  ],
  "homepage": "https://github.com/ebokoo/graphql-codegen-apollo-hooks#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ebokoo/graphql-codegen-apollo-hooks.git"
  },
  "bugs": {
    "url": "https://github.com/ebokoo/graphql-codegen-apollo-hooks/issues"
  },
  "author": {
    "name": "Ebo",
    "email": "ebo@softonus.com",
    "url": "https://github.com/ebokoo"
  },
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
