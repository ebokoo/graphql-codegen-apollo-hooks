    "@graphql-tools/utils": "^10.0.0"
  },
  "devDependencies": {
    "@apollo/client": "^4.1.6",
    "@types/node": "^22.0.0",
    "graphql": "^16.13.1",
    "typescript": "^5.0.0"
  }
